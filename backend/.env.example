PORT=4000
JWT_SECRET=replace-with-a-strong-secret
DB_PATH=./data/mental-pro.db

# Email Configuration (for appointment notifications sent to doctors)
# Option 1: Gmail (recommended for testing)
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password below (16 characters)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# Option 2: Other SMTP providers (update 'service' in appointments.js if needed)
